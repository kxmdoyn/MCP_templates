# MCP Server Template 환경변수
# cp .env.example .env 후 값 채워서 사용

# ─────────────────────────────────────────────
# 기본 설정
# ─────────────────────────────────────────────
PROJECT_NAME=MyMCPServer
MCP_GATEWAY_PORT=5000
MCP_BACKEND_BASE=http://127.0.0.1:8000
PUBLIC_BASE_URL=https://your-domain.com

# ─────────────────────────────────────────────
# DB 설정
# SQLite (기본): sqlite+aiosqlite:///./mcp.db
# PostgreSQL:   postgresql+asyncpg://user:pass@host:5432/dbname
# ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./mcp_template.db

# ─────────────────────────────────────────────
# Slack (Human-in-the-loop 사용 시)
# ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...

# ─────────────────────────────────────────────
# 스케줄러
# ─────────────────────────────────────────────
SCHEDULER_BASE_URL=http://127.0.0.1:8000

# ─────────────────────────────────────────────
# TODO: 도메인별 추가 환경변수
# YOUR_API_KEY=
# YOUR_API_BASE_URL=
# ─────────────────────────────────────────────
